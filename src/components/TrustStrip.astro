---
/** Trust strip — inline stats with green ticks; stacks on mobile (§2). */
import Icon from './Icon.astro';

interface Props {
  items: string[];
  class?: string;
}
const { items, class: className = '' } = Astro.props;
---
<ul class={`trust-strip ${className}`}>
  {items.map((item) => (
    <li>
      <Icon name="check" size={18} class="icon--green" />
      <span>{item}</span>
    </li>
  ))}
</ul>

<style>
  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3) var(--s-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .trust-strip li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--small);
    font-weight: 600;
    color: var(--navy);
  }
  :global(.section--navy) .trust-strip li { color: #fff; }

  @media (max-width: 640px) {
    .trust-strip { flex-direction: column; align-items: flex-start; }
  }
</style>
