---
/**
 * Online Consulting logo — development of the original transparent
 * dotted-globe device. No background tile (per client direction).
 * Dot fields live in src/lib/globe.ts: light variant keeps the original
 * logo's sky-blue ramp; dark variant lifts it for navy backgrounds.
 * Wordmark: two-weight Manrope in the original lockup's colours —
 * ink-navy "online", grey-navy "consulting".
 */
import { GLOBE_VIEWBOX, GLOBE_LIGHT, GLOBE_DARK } from '../lib/globe';

interface Props {
  /** 'light' = on white/off-white; 'dark' = on navy */
  variant?: 'light' | 'dark';
  markSize?: number;
  wordmark?: boolean;
}
const { variant = 'light', markSize = 40, wordmark = true } = Astro.props;
const dots = variant === 'dark' ? GLOBE_DARK : GLOBE_LIGHT;
---
<span class={`oc-logo oc-logo--${variant}`} style={`--mark: ${markSize}px;`}>
  <svg
    viewBox={GLOBE_VIEWBOX}
    class="oc-logo-mark"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
    set:html={dots}
  />
  {wordmark && (
    <span class="oc-logo-word">online<span class="oc-logo-word2">consulting</span></span>
  )}
</span>

<style>
  .oc-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    line-height: 1;
  }
  .oc-logo-mark {
    width: var(--mark);
    height: var(--mark);
    flex-shrink: 0;
    display: block;
  }
  .oc-logo-word {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: calc(var(--mark) * 0.52);
    letter-spacing: -0.015em;
    /* original lockup: ink-navy "online" */
    color: #1E3A5F;
    white-space: nowrap;
  }
  /* original lockup: lighter-weight, grey-navy "consulting" */
  .oc-logo-word2 { font-weight: 500; color: #5B7186; }
  /* on navy: original dark-version story (light blue + silver), lifted for contrast */
  .oc-logo--dark .oc-logo-word { color: #fff; }
  .oc-logo--dark .oc-logo-word2 { color: #B7C3CF; }
</style>
