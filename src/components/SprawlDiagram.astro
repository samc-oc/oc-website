---
/**
 * Vendor-sprawl diagram (Why One Partner §2) — the one piece of custom
 * illustration on the site. Inline SVG, navy nodes / Signal Blue connections /
 * --bg canvas. Stacks vertically below 768px via the two <svg> variants.
 * Caption: "Same needs. One owner."
 */
const vendors = [
  { label: 'IT support', x: 130, y: 60 },
  { label: 'Web agency', x: 330, y: 42 },
  { label: 'Hosting', x: 70, y: 180 },
  { label: 'Domains', x: 390, y: 160 },
  { label: 'Ads agency', x: 120, y: 300 },
  { label: 'Freelancer', x: 340, y: 290 },
];
const biz = { x: 230, y: 178 };
const functions = ['IT support', 'Web', 'Hosting', 'Domains', 'Ads', 'Content'];
---
<figure class="sprawl">
  <div class="sprawl-panels">
    <div class="sprawl-panel sprawl-panel--before">
      <svg
        viewBox="0 0 460 360"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Diagram of a business surrounded by six disconnected vendors — IT support, web agency, hosting, domains, ads agency and a freelancer — joined by crossing dotted lines."
      >
        {/* Crossing dotted connections */}
        {vendors.map((v) => (
          <line
            x1={biz.x} y1={biz.y} x2={v.x} y2={v.y}
            stroke="#2563EB" stroke-width="1.5" stroke-dasharray="4 5" opacity="0.55"
          />
        ))}
        {/* extra crossing lines between vendors → "a system nobody designed" */}
        <line x1={vendors[0].x} y1={vendors[0].y} x2={vendors[3].x} y2={vendors[3].y} stroke="#2563EB" stroke-width="1" stroke-dasharray="3 6" opacity="0.3" />
        <line x1={vendors[1].x} y1={vendors[1].y} x2={vendors[2].x} y2={vendors[2].y} stroke="#2563EB" stroke-width="1" stroke-dasharray="3 6" opacity="0.3" />
        <line x1={vendors[4].x} y1={vendors[4].y} x2={vendors[1].x} y2={vendors[1].y} stroke="#2563EB" stroke-width="1" stroke-dasharray="3 6" opacity="0.3" />

        {/* Vendor nodes */}
        {vendors.map((v) => (
          <g>
            <rect x={v.x - 52} y={v.y - 20} width="104" height="40" rx="20" fill="#0B1F3D" />
            <text x={v.x} y={v.y + 5} text-anchor="middle" fill="#E2E8F0" font-size="13" font-family="Inter, sans-serif" font-weight="500">{v.label}</text>
          </g>
        ))}

        {/* The business */}
        <g>
          <circle cx={biz.x} cy={biz.y} r="44" fill="#FFFFFF" stroke="#0B1F3D" stroke-width="2" />
          <text x={biz.x} y={biz.y - 2} text-anchor="middle" fill="#0B1F3D" font-size="13" font-family="Manrope, sans-serif" font-weight="700">Your</text>
          <text x={biz.x} y={biz.y + 16} text-anchor="middle" fill="#0B1F3D" font-size="13" font-family="Manrope, sans-serif" font-weight="700">business</text>
        </g>
      </svg>
      <p class="small sprawl-label">Six vendors. No owner.</p>
    </div>

    <div class="sprawl-panel sprawl-panel--after">
      <svg
        viewBox="0 0 460 360"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Diagram of the same business connected by a single solid line to one partner, Online Consulting, containing all six functions."
      >
        <line x1="120" y1="178" x2="240" y2="178" stroke="#2563EB" stroke-width="2.5" />

        <g>
          <circle cx="92" cy="178" r="44" fill="#FFFFFF" stroke="#0B1F3D" stroke-width="2" />
          <text x="92" y="176" text-anchor="middle" fill="#0B1F3D" font-size="13" font-family="Manrope, sans-serif" font-weight="700">Your</text>
          <text x="92" y="194" text-anchor="middle" fill="#0B1F3D" font-size="13" font-family="Manrope, sans-serif" font-weight="700">business</text>
        </g>

        <g>
          <rect x="240" y="64" width="190" height="228" rx="16" fill="#0B1F3D" />
          <text x="335" y="98" text-anchor="middle" fill="#FFFFFF" font-size="15" font-family="Manrope, sans-serif" font-weight="800">Online Consulting</text>
          {functions.map((f, i) => (
            <g>
              <rect x={262 + (i % 2) * 75} y={118 + Math.floor(i / 2) * 50} width="68" height="34" rx="17" fill="rgba(255,255,255,0.14)" />
              <text x={296 + (i % 2) * 75} y={139 + Math.floor(i / 2) * 50} text-anchor="middle" fill="#E2E8F0" font-size="11.5" font-family="Inter, sans-serif" font-weight="500">{f}</text>
            </g>
          ))}
        </g>
      </svg>
      <p class="small sprawl-label">One partner. All six functions.</p>
    </div>
  </div>
  <figcaption class="sprawl-caption">Same needs. One owner.</figcaption>
</figure>

<style>
  .sprawl { margin: 0; }

  .sprawl-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6);
    align-items: start;
  }

  .sprawl-panel {
    background: var(--bg);
    border-radius: var(--r-card);
    padding: var(--s-4);
  }
  .sprawl-panel svg { width: 100%; height: auto; }

  .sprawl-label {
    text-align: center;
    font-weight: 600;
    color: var(--navy);
    margin-top: var(--s-2);
  }

  .sprawl-caption {
    text-align: center;
    margin-top: var(--s-5);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: var(--h4);
    color: var(--navy);
  }

  /* Must scale legibly to 320px wide — stack vertically on mobile (§2) */
  @media (max-width: 768px) {
    .sprawl-panels { grid-template-columns: 1fr; }
  }
</style>
