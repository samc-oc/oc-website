---
/** Decorative dotted-globe motif (from the logo device, src/lib/globe.ts).
 *  variant 'dark' (lifted ramp) for navy sections; 'light' for pale ones. */
import { GLOBE_VIEWBOX, GLOBE_LIGHT, GLOBE_DARK } from '../lib/globe';

interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const dots = variant === 'dark' ? GLOBE_DARK : GLOBE_LIGHT;
---
<svg
  viewBox={GLOBE_VIEWBOX}
  class={`globe-motif ${className}`}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  set:html={dots}
/>
