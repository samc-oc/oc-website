---
/**
 * Brand panel — hero imagery developed from the dotted-globe logo device,
 * in the original sky-blue colour story on a light surface (no dark tile,
 * per client direction). Stands in for hero photography until the team/
 * office shoot lands (design system §3 bans stock).
 */
import { GLOBE_VIEWBOX, GLOBE_LIGHT } from '../lib/globe';

interface Props {
  ratio?: string;
  class?: string;
}
const { ratio = '4 / 3.4', class: className = '' } = Astro.props;
---
<div class={`brand-panel ${className}`} style={`aspect-ratio: ${ratio};`} aria-hidden="true">
  <svg viewBox={GLOBE_VIEWBOX} class="brand-panel-globe" xmlns="http://www.w3.org/2000/svg" set:html={GLOBE_LIGHT} />
  <svg viewBox={GLOBE_VIEWBOX} class="brand-panel-globe brand-panel-globe--ghost" xmlns="http://www.w3.org/2000/svg" set:html={GLOBE_LIGHT} />
</div>

<style>
  .brand-panel {
    position: relative;
    width: 100%;
    border-radius: var(--r-card);
    background:
      radial-gradient(130% 130% at 16% 0%, #FFFFFF 0%, #EAF4FB 62%, #DCEDF9 100%);
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .brand-panel-globe {
    position: absolute;
    width: 78%;
    height: auto;
    right: -12%;
    bottom: -16%;
  }
  .brand-panel-globe--ghost {
    width: 34%;
    left: 8%;
    top: 10%;
    right: auto;
    bottom: auto;
    opacity: 0.22;
  }
</style>
