---
/** Our People — supporting-pages deck. Full roster + personality bios carried
 *  over from the current /people/ page (the quirky bios stay).
 *  Photos: migrated from the old site via src/lib/team.ts (see its notes —
 *  run scripts/fetch-team-photos.sh before launch to localise the files).
 *  TODO [ACTION]: refresh team photography in a consistent style — one of the
 *  highest-value visual investments on the site. */
import Base from '../layouts/Base.astro';
import TeamCard from '../components/TeamCard.astro';
import CTABanner from '../components/CTABanner.astro';
import { breadcrumbSchema } from '../lib/schema';
import { TEAM, TEAM_GROUP_PHOTO } from '../lib/team';

const title = 'Meet the Team | Online Consulting Sydney';
const description =
  'The Sydney team behind Online Consulting — the people who answer when you call, and the personalities behind 18 years of IT support.';
---
<Base title={title} description={description} schema={[breadcrumbSchema([{ label: 'Home', href: '/' }, { label: 'Our People' }])]}>
  <section class="hero-typographic">
    <div class="container">
      <h1>The people who pick up the phone</h1>
      <p class="lead">
        No offshore call centres, no anonymous ticket queues. These are the people who manage
        your systems, build your website and answer when you call — based in our Allambie
        Heights office.
      </p>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="grid grid--3">
        {TEAM.map((member) => (
          <TeamCard name={member.name} role={member.role} bio={member.bio} photo={member.photo} />
        ))}
      </div>
    </div>
  </section>

  <section class="team-band" aria-label="The wider Online Consulting team">
    <img
      src={TEAM_GROUP_PHOTO}
      alt="The wider Online Consulting development team together outdoors"
      loading="lazy"
    />
  </section>

  <CTABanner heading="Put names and faces to your IT" />
</Base>

<style>
  .hero-typographic { background: var(--bg); padding-block: var(--section-pad-lg); }
  .hero-typographic .lead { margin-top: var(--s-5); max-width: 58ch; }

  .team-band { max-height: 380px; overflow: hidden; }
  .team-band img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* source banner is darkened for text overlay — lift it for standalone use */
    filter: brightness(1.55) contrast(1.04);
  }
</style>
