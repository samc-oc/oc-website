---
/** Privacy Policy — content migrated verbatim from the current site
 *  (src/lib/legacy/privacy-policy.json). URL unchanged. */
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { breadcrumbSchema } from '../lib/schema';
import legacy from '../lib/legacy/privacy-policy.json';

const title = 'Privacy Policy | Online Consulting';
const description = legacy.metaDescription;
const crumbs = [{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }];
---
<Base title={title} description={description} schema={[breadcrumbSchema(crumbs)]}>
  <section class="page-header">
    <div class="container">
      <Breadcrumb items={crumbs} />
      <h1>{legacy.title}</h1>
    </div>
  </section>
  <section class="section section--white">
    <div class="container">
      <div class="prose" set:html={legacy.html} />
    </div>
  </section>
</Base>

<style>
  .page-header { background: var(--bg); padding-block: var(--s-7); }
  .page-header h1 { margin-top: var(--s-5); }
</style>
